    let list = state.atendimentos;
    if(q) list = list.filter(a => (a.paciente_nome||'').toLowerCase().includes(q) || (a.cliente_nome||'').toLowerCase().includes(q));
    if(status) list = list.filter(a => a.status === status);
    renderHistTable(list);
  }
  document.getElementById('histSearch').addEventListener('input', applyFilters);
  document.getElementById('histStatus').addEventListener('change', applyFilters);
  applyFilters();
}

function renderHistTable(list){
  const wrap = document.getElementById('histTableWrap');
  if(list.length === 0){ wrap.innerHTML = `<div class="empty-state"><div class="em-icon">🕘</div>Nenhum atendimento encontrado.</div>`; return; }
  wrap.innerHTML = `
    <table>
      <thead><tr><th>Data agendada</th><th>Paciente</th><th>Cliente</th><th>Procedimento</th><th>Status</th><th>Valor</th></tr></thead>
      <tbody>
        ${list.map(a => `
          <tr class="clickable" onclick="location.hash='#/atendimento/${a.id}'">
            <td>${fmtDate(a.data_hora_agendada)}</td>
            <td>${esc(a.paciente_nome)}</td>
            <td>${esc(a.cliente_nome)}</td>
            <td>${esc(a.procedimento_nome)}</td>
            <td><span class="badge badge-${a.status}">${statusLabel(a.status)}</span></td>
            <td>${fmtMoney(a.valor_cobrado)}</td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  `;
}

/* =========================================================
   BOOT
========================================================= */
(async function boot(){
  app.innerHTML = `<div class="empty-state">Carregando Salus...</div>`;
  await loadAll();
  router();
})();
</script>
