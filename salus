<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Salus · by Spatas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root{
    --verde: #3D5A4A;
    --verde-escuro: #2C4437;
    --dourado: #B8952A;
    --off-white: #F5F0E8;
    --verde-claro: #E8EDE9;
    --branco: #FFFFFF;
    --alerta: #B85C38;
    --texto: #2A2E2B;
    --texto-suave: #6B7570;
    --borda: #DDD4C4;
    --sombra: 0 4px 18px rgba(61,90,74,0.08);
    --raio: 10px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--off-white);
    color:var(--texto);
    font-family:'Inter',sans-serif;
    min-height:100vh;
  }
  h1,h2,h3,.serif{font-family:'Playfair Display',serif;}

  /* ---------- TOPBAR ---------- */
  .topbar{
    position:sticky; top:0; z-index:50;
    background:var(--verde);
    color:var(--off-white);
    display:flex; align-items:center; gap:14px;
    padding:14px 20px;
    box-shadow:var(--sombra);
  }
  .hamburger{
    background:none; border:none; cursor:pointer;
    width:38px; height:38px; display:flex; flex-direction:column;
    justify-content:center; align-items:center; gap:5px;
    padding:0; border-radius:8px;
  }
  .hamburger:hover{background:rgba(255,255,255,0.08);}
  .hamburger span{display:block; width:22px; height:2px; background:var(--dourado); border-radius:2px;}
  .brand{display:flex; align-items:center; gap:10px;}
  .brand-icon{width:32px; height:32px; flex-shrink:0;}
  .brand-text{display:flex; flex-direction:column; line-height:1;}
  .brand-text .name{font-family:'Playfair Display',serif; font-size:22px; font-weight:600; color:var(--off-white);}
  .brand-text .sub{font-size:9px; letter-spacing:2.5px; color:var(--dourado); margin-top:2px;}

  /* ---------- SIDEBAR ---------- */
  .overlay{
    position:fixed; inset:0; background:rgba(20,30,24,0.35);
    opacity:0; pointer-events:none; transition:opacity .25s ease; z-index:60;
  }
  .overlay.open{opacity:1; pointer-events:auto;}
  .sidebar{
    position:fixed; top:0; left:0; height:100%; width:280px;
    background:var(--branco);
    transform:translateX(-100%);
    transition:transform .28s ease;
    z-index:70;
    box-shadow:4px 0 24px rgba(0,0,0,0.15);
    display:flex; flex-direction:column;
  }
  .sidebar.open{transform:translateX(0);}
  .sidebar-header{
    padding:22px 20px; border-bottom:1px solid var(--borda);
    display:flex; align-items:center; gap:10px;
  }
  .sidebar-header .name{font-family:'Playfair Display',serif; font-size:20px; color:var(--verde-escuro);}
  .sidebar-header .sub{font-size:9px; letter-spacing:2.5px; color:var(--dourado);}
  .sidebar nav{display:flex; flex-direction:column; padding:10px 0; flex:1; overflow-y:auto;}
  .sidebar nav a{
    padding:13px 22px; color:var(--texto); text-decoration:none;
    font-size:14.5px; font-weight:500; border-left:3px solid transparent;
    display:flex; align-items:center; gap:12px;
    transition:background .15s, border-color .15s;
  }
  .sidebar nav a:hover{background:var(--verde-claro);}
  .sidebar nav a.active{border-left-color:var(--dourado); background:var(--verde-claro); color:var(--verde-escuro); font-weight:600;}
  .sidebar nav .section-label{
    padding:16px 22px 6px; font-size:10.5px; letter-spacing:1.5px;
    text-transform:uppercase; color:var(--texto-suave); font-weight:600;
  }
  .sidebar-footer{padding:16px 22px; font-size:11px; color:var(--texto-suave); border-top:1px solid var(--borda);}

  /* ---------- LAYOUT ---------- */
  #app{max-width:1000px; margin:0 auto; padding:28px 20px 60px;}
  .page-title{margin:0 0 6px; font-size:28px; color:var(--verde-escuro);}
  .page-subtitle{margin:0 0 26px; color:var(--texto-suave); font-size:14.5px;}

  .card{
    background:var(--branco); border-radius:var(--raio);
    box-shadow:var(--sombra); padding:24px; margin-bottom:22px;
    border:1px solid var(--borda);
  }
  .card h3{margin:0 0 18px; font-size:18px; color:var(--verde-escuro); font-weight:600;}

  /* ---------- DASHBOARD ---------- */
  .stats-grid{display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:16px; margin-bottom:26px;}
  .stat-card{
    background:var(--branco); border-radius:var(--raio); padding:20px;
    box-shadow:var(--sombra); border-top:3px solid var(--dourado);
  }
  .stat-card .num{font-family:'Playfair Display',serif; font-size:34px; color:var(--verde-escuro); line-height:1;}
  .stat-card .label{font-size:12.5px; color:var(--texto-suave); margin-top:6px;}
  .quick-actions{display:flex; flex-wrap:wrap; gap:12px; margin-bottom:28px;}

  /* ---------- FORMS ---------- */
  .form-grid{display:grid; grid-template-columns:1fr 1fr; gap:16px;}
  .form-grid.single{grid-template-columns:1fr;}
  .form-group{display:flex; flex-direction:column; gap:6px; margin-bottom:14px;}
  .form-group.full{grid-column:1 / -1;}
  label{font-size:13px; font-weight:600; color:var(--verde-escuro);}
  input, select, textarea{
    font-family:'Inter',sans-serif; font-size:14.5px;
    padding:10px 12px; border:1px solid var(--borda); border-radius:8px;
    background:var(--off-white); color:var(--texto); width:100%;
  }
  input:focus, select:focus, textarea:focus{
    outline:none; border-color:var(--dourado); box-shadow:0 0 0 3px rgba(184,149,42,0.18);
    background:var(--branco);
  }
  textarea{resize:vertical; min-height:70px;}
  .hint{font-size:12px; color:var(--texto-suave);}

  /* ---------- BUTTONS ---------- */
  .btn{
    display:inline-flex; align-items:center; gap:8px;
    font-family:'Inter',sans-serif; font-size:14px; font-weight:600;
    padding:11px 20px; border-radius:8px; border:none; cursor:pointer;
    text-decoration:none; transition:filter .15s, transform .1s;
  }
  .btn:active{transform:scale(0.98);}
  .btn-primary{background:var(--verde); color:var(--off-white);}
  .btn-primary:hover{filter:brightness(1.1);}
  .btn-gold{background:var(--dourado); color:var(--branco);}
  .btn-gold:hover{filter:brightness(1.08);}
  .btn-outline{background:transparent; color:var(--verde); border:1.5px solid var(--verde);}
  .btn-outline:hover{background:var(--verde-claro);}
  .btn-danger{background:transparent; color:var(--alerta); border:1.5px solid var(--alerta);}
  .btn-danger:hover{background:rgba(184,92,56,0.08);}
  .btn-sm{padding:7px 12px; font-size:12.5px;}
  .form-actions{display:flex; gap:12px; margin-top:6px; flex-wrap:wrap;}

  /* ---------- TABLES ---------- */
  table{width:100%; border-collapse:collapse; font-size:13.8px;}
  th{
    text-align:left; padding:10px 12px; background:var(--verde-claro);
    color:var(--verde-escuro); font-size:11.5px; letter-spacing:0.5px;
    text-transform:uppercase; font-weight:600;
  }
  td{padding:11px 12px; border-bottom:1px solid var(--borda); vertical-align:top;}
  tr.clickable{cursor:pointer;}
  tr.clickable:hover td{background:var(--verde-claro);}
  .table-wrap{overflow-x:auto;}
  .empty-state{padding:40px 20px; text-align:center; color:var(--texto-suave);}
  .empty-state .em-icon{font-size:32px; margin-bottom:10px;}

  /* ---------- BADGES ---------- */
  .badge{display:inline-block; padding:4px 10px; border-radius:20px; font-size:11.5px; font-weight:600;}
  .badge-agendado{background:#EFE3C0; color:#8A6D14;}
  .badge-em_andamento{background:#D9E7F0; color:#2E6A8C;}
  .badge-concluido{background:#DCEBDF; color:#2C6B41;}
  .badge-cancelado{background:#F2DCD4; color:var(--alerta);}

  /* ---------- FILTERS ---------- */
  .filters-row{display:flex; gap:12px; flex-wrap:wrap; margin-bottom:18px;}
  .filters-row input, .filters-row select{width:auto; min-width:160px;}

  /* ---------- TOAST ---------- */
  #toast{
    position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(100px);
    background:var(--verde-escuro); color:var(--off-white); padding:13px 22px;
    border-radius:8px; font-size:14px; box-shadow:0 6px 20px rgba(0,0,0,0.2);
    z-index:200; transition:transform .3s ease; max-width:90vw;
  }
  #toast.show{transform:translateX(-50%) translateY(0);}
  #toast.error{background:var(--alerta);}

  @media(max-width:640px){
    .form-grid{grid-template-columns:1fr;}
    .stats-grid{grid-template-columns:repeat(2,1fr);}
  }
</style>
</head>
<body>

<div class="topbar">
  <button class="hamburger" id="hamburgerBtn" aria-label="Abrir menu">
    <span></span><span></span><span></span>
  </button>
  <div class="brand">
    <svg class="brand-icon" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M74,26 A36,36 0 1 0 74,74" stroke="#2C4437" stroke-width="3" stroke-linecap="round"/>
      <path d="M17,64 Q27,59 34,68" stroke="#8FA593" stroke-width="2.6" stroke-linecap="round"/>
      <path d="M21,61 Q25,54 32,56" stroke="#8FA593" stroke-width="2.6" stroke-linecap="round"/>
      <path d="M40,50 C35,40 38,27 49,24 C58,22 67,27 70,36 C72,41 70,45 66,45 L58,42 C54,44 52,48 53,53" stroke="#B8952A" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M44,33 C40,37 39,43 43,47" stroke="#B8952A" stroke-width="2.6" stroke-linecap="round"/>
      <path d="M45,58 L41,48 L50,52 L59,46 L57,55 C61,58 62,64 58,69 C52,73 44,71 42,65 C41,61 42,59 45,58 Z" stroke="#B8952A" stroke-width="2.6" stroke-linejoin="round" stroke-linecap="round"/>
    </svg>
    <div class="brand-text">
      <span class="name">Salus</span>
      <span class="sub">BY SPATAS</span>
    </div>
  </div>
</div>

<div class="overlay" id="overlay"></div>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="brand-text">
      <span class="name">Salus</span>
      <span class="sub">MENU</span>
    </div>
  </div>
  <nav id="sidebarNav">
    <a href="#/" data-route="/">🏠 Início</a>
    <a href="#/atendimento/novo" data-route="/atendimento/novo">📋 Novo Atendimento</a>
    <a href="#/historico" data-route="/historico">🕘 Histórico</a>
    <div class="section-label">Cadastros</div>
    <a href="#/clientes" data-route="/clientes">👤 Clientes</a>
    <a href="#/pacientes" data-route="/pacientes">🐾 Pacientes</a>
    <a href="#/procedimentos" data-route="/procedimentos">🧴 Procedimentos</a>
  </nav>
  <div class="sidebar-footer">Salus v1 · by Spatas · uso interno</div>
</aside>

<div id="app"></div>
<div id="toast"></div>

<script>
/* =========================================================
   CONFIG SUPABASE
========================================================= */
const SUPABASE_URL = 'https://bhydgbvthgpggknzymmy.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJoeWRnYnZ0aGdwZ2drbnp5bW15Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMxNTMxOTUsImV4cCI6MjA5ODcyOTE5NX0.TZalYTuNpKuXPHJF7FxL5DNDGM8N5nhDdgZ6uZD47Hw';

if(typeof supabase === 'undefined'){
  document.getElementById('app').innerHTML = `<div class="empty-state"><div class="em-icon">⚠️</div>
    Não foi possível carregar a biblioteca do Supabase.<br>
    Verifique sua conexão com a internet e recarregue a página.</div>`;
  throw new Error('SDK do Supabase não carregado — verifique a tag <script> do CDN no <head>.');
}
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

/* =========================================================
   ESTADO GLOBAL (cache local dos dados)
========================================================= */
const state = { clientes: [], pacientes: [], procedimentos: [], atendimentos: [] };

/* =========================================================
   HELPERS
========================================================= */
function toast(msg, isError=false){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = isError ? 'error show' : 'show';
  setTimeout(()=> t.classList.remove('show'), 3200);
}
function fmtDate(d){
  if(!d) return '—';
  const dt = new Date(d);
  return dt.toLocaleString('pt-BR', {day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'});
}
function fmtDateOnly(d){
  if(!d) return '—';
  const dt = new Date(d + 'T00:00:00');
  return dt.toLocaleDateString('pt-BR');
}
function fmtMoney(v){
  if(v === null || v === undefined || v === '') return '—';
  return Number(v).toLocaleString('pt-BR', {style:'currency', currency:'BRL'});
}
function toInputDatetime(v){
  if(!v) return '';
  const dt = new Date(v);
  const pad = n => String(n).padStart(2,'0');
  return `${dt.getFullYear()}-${pad(dt.getMonth()+1)}-${pad(dt.getDate())}T${pad(dt.getHours())}:${pad(dt.getMinutes())}`;
}
function statusLabel(s){
  return {agendado:'Agendado', em_andamento:'Em andamento', concluido:'Concluído', cancelado:'Cancelado'}[s] || s;
}
function esc(s){
  if(s === null || s === undefined) return '';
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

/* =========================================================
   CARREGAMENTO DE DADOS
========================================================= */
async function loadAll(){
  const [c, p, pr, at] = await Promise.all([
    sb.from('dim_cliente').select('*').order('nome'),
    sb.from('dim_paciente').select('*').order('nome'),
    sb.from('dim_procedimento').select('*').order('nome'),
    sb.from('vw_atendimento_completo').select('*').order('data_hora_agendada', {ascending:false})
  ]);
  if(c.error) toast('Erro ao carregar clientes: '+c.error.message, true); else state.clientes = c.data;
  if(p.error) toast('Erro ao carregar pacientes: '+p.error.message, true); else state.pacientes = p.data;
  if(pr.error) toast('Erro ao carregar procedimentos: '+pr.error.message, true); else state.procedimentos = pr.data;
  if(at.error) toast('Erro ao carregar atendimentos: '+at.error.message, true); else state.atendimentos = at.data;
}

/* =========================================================
   ROTEADOR
========================================================= */
const app = document.getElementById('app');

function router(){
  const hash = location.hash.replace('#','') || '/';
  const parts = hash.split('/').filter(Boolean);

  document.querySelectorAll('.sidebar nav a').forEach(a=>{
    a.classList.toggle('active', a.getAttribute('href') === '#'+hash);
  });
  closeSidebar();

  if(parts.length === 0) return renderHome();
  if(parts[0] === 'clientes') return renderClientes();
  if(parts[0] === 'pacientes') return renderPacientes();
  if(parts[0] === 'procedimentos') return renderProcedimentos();
  if(parts[0] === 'historico') return renderHistorico();
  if(parts[0] === 'atendimento' && parts[1] === 'novo') return renderAtendimentoForm(null);
  if(parts[0] === 'atendimento' && parts[1]) return renderAtendimentoForm(parts[1]);
  app.innerHTML = `<div class="empty-state"><div class="em-icon">🔍</div>Página não encontrada.</div>`;
}
window.addEventListener('hashchange', router);

/* =========================================================
   SIDEBAR
========================================================= */
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('overlay');
function openSidebar(){ sidebar.classList.add('open'); overlay.classList.add('open'); }
function closeSidebar(){ sidebar.classList.remove('open'); overlay.classList.remove('open'); }
document.getElementById('hamburgerBtn').addEventListener('click', ()=>{
  sidebar.classList.contains('open') ? closeSidebar() : openSidebar();
});
overlay.addEventListener('click', closeSidebar);

/* =========================================================
   VIEW: HOME / DASHBOARD
========================================================= */
function renderHome(){
  const hoje = new Date(); hoje.setHours(0,0,0,0);
  const agendadosFuturos = state.atendimentos.filter(a => a.status === 'agendado' && a.data_hora_agendada && new Date(a.data_hora_agendada) >= hoje);
  const proximos = [...agendadosFuturos].sort((a,b)=> new Date(a.data_hora_agendada) - new Date(b.data_hora_agendada)).slice(0,5);

  app.innerHTML = `
    <h1 class="page-title serif">Olá, Dra. Jennifer</h1>
    <p class="page-subtitle">Tudo em um só lugar, cuidado em cada detalhe. Aqui está o resumo do consultório hoje.</p>

    <div class="stats-grid">
      <div class="stat-card"><div class="num">${state.clientes.length}</div><div class="label">Clientes cadastrados</div></div>
      <div class="stat-card"><div class="num">${state.pacientes.length}</div><div class="label">Pacientes cadastrados</div></div>
      <div class="stat-card"><div class="num">${state.procedimentos.length}</div><div class="label">Procedimentos ativos</div></div>
      <div class="stat-card"><div class="num">${agendadosFuturos.length}</div><div class="label">Atendimentos agendados</div></div>
    </div>

    <div class="quick-actions">
      <a class="btn btn-primary" href="#/atendimento/novo">+ Novo Atendimento</a>
      <a class="btn btn-outline" href="#/clientes">+ Cliente</a>
      <a class="btn btn-outline" href="#/pacientes">+ Paciente</a>
      <a class="btn btn-outline" href="#/procedimentos">+ Procedimento</a>
    </div>

    <div class="card">
      <h3>Próximos agendamentos</h3>
      ${proximos.length === 0 ? `<div class="empty-state"><div class="em-icon">📅</div>Nenhum atendimento agendado no momento.</div>` : `
      <div class="table-wrap"><table>
        <thead><tr><th>Data</th><th>Paciente</th><th>Cliente</th><th>Procedimento</th><th>Status</th></tr></thead>
        <tbody>
          ${proximos.map(a => `
            <tr class="clickable" onclick="location.hash='#/atendimento/${a.id}'">
              <td>${fmtDate(a.data_hora_agendada)}</td>
              <td>${esc(a.paciente_nome)}</td>
              <td>${esc(a.cliente_nome)}</td>
              <td>${esc(a.procedimento_nome)}</td>
              <td><span class="badge badge-${a.status}">${statusLabel(a.status)}</span></td>
            </tr>
          `).join('')}
        </tbody>
      </table></div>`}
    </div>
  `;
}

/* =========================================================
   VIEW: CLIENTES
========================================================= */
let clienteEditId = null;

function renderClientes(){
  clienteEditId = null;
  app.innerHTML = `
    <h1 class="page-title serif">Clientes</h1>
    <p class="page-subtitle">Cadastro dos tutores dos pacientes.</p>

    <div class="card">
      <h3 id="clienteFormTitle">Novo cliente</h3>
      <form id="clienteForm">
        <div class="form-grid">
          <div class="form-group full"><label>Nome completo *</label><input type="text" id="cl_nome" required></div>
          <div class="form-group"><label>Telefone</label><input type="text" id="cl_telefone" placeholder="(31) 90000-0000"></div>
          <div class="form-group"><label>E-mail</label><input type="email" id="cl_email"></div>
          <div class="form-group"><label>CPF</label><input type="text" id="cl_cpf"></div>
          <div class="form-group"><label>Endereço</label><input type="text" id="cl_endereco"></div>
          <div class="form-group full"><label>Observações</label><textarea id="cl_obs"></textarea></div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Salvar cliente</button>
          <button type="button" class="btn btn-outline" id="clienteCancelBtn" style="display:none;">Cancelar edição</button>
        </div>
      </form>
    </div>

    <div class="card">
      <h3>Clientes cadastrados (${state.clientes.length})</h3>
      <div class="filters-row"><input type="text" id="clienteSearch" placeholder="Buscar por nome..."></div>
      <div class="table-wrap" id="clienteTableWrap"></div>
    </div>
  `;

  renderClienteTable(state.clientes);
  document.getElementById('clienteSearch').addEventListener('input', e=>{
    const q = e.target.value.toLowerCase();
    renderClienteTable(state.clientes.filter(c => c.nome.toLowerCase().includes(q)));
  });
  document.getElementById('clienteForm').addEventListener('submit', submitCliente);
  document.getElementById('clienteCancelBtn').addEventListener('click', resetClienteForm);
}

function renderClienteTable(list){
  const wrap = document.getElementById('clienteTableWrap');
  if(list.length === 0){ wrap.innerHTML = `<div class="empty-state"><div class="em-icon">👤</div>Nenhum cliente encontrado.</div>`; return; }
  wrap.innerHTML = `
    <table>
      <thead><tr><th>Nome</th><th>Telefone</th><th>E-mail</th><th></th></tr></thead>
      <tbody>
        ${list.map(c => `
          <tr>
            <td>${esc(c.nome)}</td>
            <td>${esc(c.telefone) || '—'}</td>
            <td>${esc(c.email) || '—'}</td>
            <td>
              <button class="btn btn-sm btn-outline" onclick="editCliente('${c.id}')">Editar</button>
              <button class="btn btn-sm btn-danger" onclick="deleteCliente('${c.id}')">Excluir</button>
            </td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  `;
}

function editCliente(id){
  const c = state.clientes.find(x=>x.id===id);
  if(!c) return;
  clienteEditId = id;
  document.getElementById('clienteFormTitle').textContent = 'Editando: ' + c.nome;
  document.getElementById('cl_nome').value = c.nome || '';
  document.getElementById('cl_telefone').value = c.telefone || '';
